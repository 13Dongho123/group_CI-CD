GROUP_ENV=dev
AWS_DEFAULT_REGION=ap-northeast-2
BATCH_LOADER_LAMBDA_NAME=lifesync-dev-09-streaming-api-la-BatchLoaderLambda-REPLACE
# EC2 /etc/group-agent/env sets SOURCE_NAME to bank|card|…|online_insurance (matches BatchLoaderLambda).
SOURCE_NAME=bank
GROUP_BATCH_INTERVAL_SEC=600
# Max rows pulled from MySQL per Lambda invoke (time-ordered since last watermark).
GROUP_BATCH_RECORDS=100
# Rows inserted each tick before export; 0 = 적재는 다른 경로만, 이 job은 export만.
GROUP_INSERT_PER_TICK=20
GROUP_LOCAL_BATCH_DIR=/opt/group-agent/batches
GROUP_STATE_DIR=/opt/group-agent/state
# false = legacy synthetic JSON without MySQL (dev only).
GROUP_USE_MYSQL_EXPORT=true
# true = 한 번만 export 후 종료. cron 예: */2 * * * * … /usr/bin/python3 /opt/group-agent/active_sender.py (env에 GROUP_RUN_ONCE=1)
GROUP_RUN_ONCE=false

AUTO_START_GROUP_SENDER=false
